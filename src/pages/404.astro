---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found" description="The page you're looking for doesn't exist. Head back to Kids Soccer Academy's homepage to find programs, schedules, and free trial information.">

  <section class="relative z-10 w-full bg-white">
    <div class="max-w-3xl mx-auto px-6 pt-32 pb-24 text-center">
      <p class="text-8xl font-bold text-slate-200">404</p>
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-slate-900 mt-6">Page not found</h1>
      <p class="text-lg font-light text-slate-500 mt-4">The page you're looking for doesn't exist or has been moved.</p>
      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/" class="inline-flex items-center justify-center bg-pink-500 text-white text-base font-medium px-8 py-4 rounded-xl hover:bg-pink-600 transition-colors duration-200 shadow-sm">
          Back to Home
        </a>
        <a href="/free-trial" class="inline-flex items-center justify-center bg-slate-100 text-slate-900 text-base font-medium px-8 py-4 rounded-xl hover:bg-slate-200 transition-colors duration-200">
          Book Free Trial
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
