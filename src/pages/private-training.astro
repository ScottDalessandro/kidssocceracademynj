---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBlock from '../components/CtaBlock.astro';
---

<BaseLayout title="Private Training">

  <!-- Hero -->
  <section class="relative z-10 w-full bg-white">
    <div class="max-w-7xl mx-auto px-6 pt-24 pb-12 md:pt-32 md:pb-16">
      <div class="flex flex-col items-center text-center max-w-3xl mx-auto">
        <p class="text-xs font-medium uppercase tracking-[0.08em] text-sky-400 mb-3">PRIVATE TRAINING</p>
        <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-slate-900 leading-[1.1]">Personalized Training. Accelerated Results.</h1>
        <p class="text-lg font-light text-slate-500 mt-5 leading-relaxed max-w-2xl">1-on-1 and small group sessions designed to target specific skills, build confidence, and take your child's game to the next level.</p>
      </div>
    </div>
  </section>

  <!-- Training Options -->
  <section class="relative z-10 w-full bg-slate-50 border-t border-slate-100">
    <div class="max-w-7xl mx-auto px-6 py-20">
      <div class="flex flex-col items-center text-center mb-16">
        <p class="text-xs font-medium uppercase tracking-widest text-sky-400 mb-3">OPTIONS</p>
        <h2 class="text-4xl font-bold tracking-tight text-slate-900">Choose Your Training Format</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

        <!-- 1-on-1 -->
        <div class="scroll-fade bg-white rounded-xl shadow-sm border border-slate-200 p-8 flex flex-col opacity-0 translate-y-4 transition-all duration-500 ease-out">
          <div class="w-14 h-14 rounded-xl bg-pink-50 flex items-center justify-center text-pink-500 mb-5">
            <iconify-icon icon="solar:user-linear" width="28"></iconify-icon>
          </div>
          <h3 class="text-xl font-bold text-slate-900">1-on-1 Training</h3>
          <p class="text-sm font-light text-slate-500 leading-relaxed mt-3 flex-1">Fully personalized coaching focused on your child's specific needs. Technical skills, tactical awareness, or confidence building — the session is theirs.</p>
          <div class="mt-6 pt-6 border-t border-slate-100">
            <span class="text-3xl font-bold text-slate-900">$75</span>
            <span class="text-sm font-light text-slate-400 ml-1">/session</span>
          </div>
          <a href="/contact" class="mt-6 inline-flex items-center justify-center w-full bg-pink-500 text-white text-sm font-medium py-3.5 rounded-xl hover:bg-pink-600 transition-colors duration-200 shadow-sm">
            Book a Session
          </a>
        </div>

        <!-- Small Group -->
        <div class="scroll-fade bg-white rounded-xl shadow-sm border border-slate-200 p-8 flex flex-col opacity-0 translate-y-4 transition-all duration-500 ease-out" style="transition-delay: 150ms;">
          <div class="w-14 h-14 rounded-xl bg-sky-50 flex items-center justify-center text-sky-400 mb-5">
            <iconify-icon icon="solar:users-group-rounded-linear" width="28"></iconify-icon>
          </div>
          <h3 class="text-xl font-bold text-slate-900">Small Group (2-3 Players)</h3>
          <p class="text-sm font-light text-slate-500 leading-relaxed mt-3 flex-1">Train with friends or teammates. A great way to get focused coaching at a lower per-player cost while keeping the energy high.</p>
          <div class="mt-6 pt-6 border-t border-slate-100">
            <span class="text-3xl font-bold text-slate-900">$50</span>
            <span class="text-sm font-light text-slate-400 ml-1">/player per session</span>
          </div>
          <a href="/contact" class="mt-6 inline-flex items-center justify-center w-full bg-pink-500 text-white text-sm font-medium py-3.5 rounded-xl hover:bg-pink-600 transition-colors duration-200 shadow-sm">
            Book a Session
          </a>
        </div>

        <!-- Goalie -->
        <div class="scroll-fade bg-white rounded-xl shadow-sm border border-slate-200 p-8 flex flex-col opacity-0 translate-y-4 transition-all duration-500 ease-out" style="transition-delay: 300ms;">
          <div class="w-14 h-14 rounded-xl bg-pink-50 flex items-center justify-center text-pink-500 mb-5">
            <iconify-icon icon="solar:hand-shake-linear" width="28"></iconify-icon>
          </div>
          <h3 class="text-xl font-bold text-slate-900">Goalie-Specific Training</h3>
          <p class="text-sm font-light text-slate-500 leading-relaxed mt-3 flex-1">Specialized goalkeeper coaching covering positioning, shot-stopping, distribution, and the mental side of playing in goal.</p>
          <div class="mt-6 pt-6 border-t border-slate-100">
            <span class="text-3xl font-bold text-slate-900">$75</span>
            <span class="text-sm font-light text-slate-400 ml-1">/session</span>
          </div>
          <a href="/contact" class="mt-6 inline-flex items-center justify-center w-full bg-pink-500 text-white text-sm font-medium py-3.5 rounded-xl hover:bg-pink-600 transition-colors duration-200 shadow-sm">
            Book a Session
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- Who It's For -->
  <section class="relative z-10 w-full bg-white border-t border-slate-100">
    <div class="max-w-7xl mx-auto px-6 py-20">
      <div class="flex flex-col items-center text-center mb-16">
        <p class="text-xs font-medium uppercase tracking-widest text-sky-400 mb-3">WHO IT'S FOR</p>
        <h2 class="text-4xl font-bold tracking-tight text-slate-900">Private training is ideal for</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {[
          { icon: 'solar:cup-star-linear', title: 'Travel Team Prep', text: 'Get ready for tryouts or sharpen skills during the season.' },
          { icon: 'solar:target-linear', title: 'Filling Skill Gaps', text: 'Focused work on weak areas like weak foot, first touch, or passing.' },
          { icon: 'solar:flag-linear', title: 'Position-Specific Work', text: 'Train the skills that matter for your child\'s position on the field.' },
          { icon: 'solar:calendar-linear', title: 'Off-Season Development', text: 'Keep improving when the team season is over. Stay sharp year-round.' },
        ].map((item, i) => (
          <div class="scroll-fade flex flex-col items-center text-center opacity-0 translate-y-4 transition-all duration-500 ease-out" style={`transition-delay: ${i * 150}ms;`}>
            <div class="w-16 h-16 rounded-full bg-sky-100 flex items-center justify-center text-sky-400">
              <iconify-icon icon={item.icon} width="32"></iconify-icon>
            </div>
            <h3 class="text-lg font-semibold text-slate-900 mt-4">{item.title}</h3>
            <p class="text-sm font-light text-slate-500 leading-relaxed mt-2 max-w-[240px] mx-auto">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Coach Credentials -->
  <section class="relative z-10 w-full bg-slate-50 border-t border-slate-100">
    <div class="max-w-3xl mx-auto px-6 py-20">
      <div class="scroll-fade flex flex-col items-center text-center opacity-0 translate-y-4 transition-all duration-500 ease-out">
        <div class="w-16 h-16 rounded-full bg-pink-50 flex items-center justify-center text-pink-500 mb-5">
          <iconify-icon icon="solar:verified-check-linear" width="32"></iconify-icon>
        </div>
        <h2 class="text-3xl font-bold tracking-tight text-slate-900">Trained by Certified Coaches</h2>
        <p class="text-base font-light text-slate-500 leading-relaxed mt-4 max-w-xl">All private training sessions are led by our experienced, background-checked, CPR/First Aid certified coaching staff. Every coach at KSA is committed to your child's development — on and off the field.</p>
        <a href="/about" class="mt-6 inline-flex items-center text-sm font-medium text-pink-500 hover:underline">
          Meet our coaches <iconify-icon icon="solar:arrow-right-linear" width="16" class="ml-1"></iconify-icon>
        </a>
      </div>
    </div>
  </section>

  <CtaBlock heading="Ready to take it to the next level?" body="Book a private session." buttonText="Contact Us" buttonHref="/contact" />

</BaseLayout>
