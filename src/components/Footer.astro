---
import programs from '../data/programs.json';
const soccerPrograms = programs.filter(p => !p.isAddon).sort((a, b) => a.order - b.order);
---

<footer class="bg-slate-900 pt-16 pb-8">
  <div class="max-w-7xl mx-auto px-6">

    <!-- Top Section: 4 Columns -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">

      <!-- Column 1: Brand -->
      <div>
        <img src="/kids-soccer-academy-logo.avif" alt="Kids Soccer Academy" class="h-16 w-auto" />
        <p class="mt-3 text-sm font-light text-slate-400">
          681 Lawlins Rd #70, Wyckoff, NJ 07481
        </p>
        <a href="tel:+12016964195" class="block mt-1 text-sm font-normal text-slate-400 hover:text-white transition-colors duration-200">
          (201) 696-4195
        </a>

        <!-- Social Icons -->
        <div class="mt-5 flex items-center gap-4">
          <a href="https://www.facebook.com/p/Kids-Soccer-Academy-61573193837254/" target="_blank" rel="noopener" class="text-slate-400 hover:text-white transition-colors duration-200">
            <iconify-icon icon="simple-icons:facebook" width="20"></iconify-icon>
          </a>
          <a href="#" class="text-slate-400 hover:text-white transition-colors duration-200">
            <iconify-icon icon="simple-icons:instagram" width="20"></iconify-icon>
          </a>
          <a href="#" class="text-slate-400 hover:text-white transition-colors duration-200">
            <iconify-icon icon="simple-icons:youtube" width="20"></iconify-icon>
          </a>
          <a href="#" class="text-slate-400 hover:text-white transition-colors duration-200">
            <iconify-icon icon="simple-icons:tiktok" width="20"></iconify-icon>
          </a>
        </div>
      </div>

      <!-- Column 2: Programs -->
      <div>
        <h4 class="text-sm font-medium text-white uppercase tracking-widest">Programs</h4>
        <ul class="mt-4 flex flex-col text-sm font-light text-slate-400 leading-loose">
          {soccerPrograms.map(p => (
            <li><a href={`/programs/${p.slug}`} class="hover:text-white transition-colors duration-200 block">{p.name}</a></li>
          ))}
          <li><a href="/programs/kids-fitness" class="hover:text-white transition-colors duration-200 block">Kids Fitness Academy</a></li>
        </ul>
      </div>

      <!-- Column 3: Quick Links -->
      <div>
        <h4 class="text-sm font-medium text-white uppercase tracking-widest">Quick Links</h4>
        <ul class="mt-4 flex flex-col text-sm font-light text-slate-400 leading-loose">
          <li><a href="/schedule" class="hover:text-white transition-colors duration-200 block">Schedule</a></li>
          <li><a href="/about" class="hover:text-white transition-colors duration-200 block">About Our Coaches</a></li>
          <li><a href="/birthday-parties" class="hover:text-white transition-colors duration-200 block">Birthday Parties</a></li>
          <li><a href="/private-training" class="hover:text-white transition-colors duration-200 block">Private Training</a></li>
          <li><a href="/faq" class="hover:text-white transition-colors duration-200 block">FAQ</a></li>
          <li><a href="/contact" class="hover:text-white transition-colors duration-200 block">Contact</a></li>
        </ul>
      </div>

      <!-- Column 4: Get Started -->
      <div>
        <h4 class="text-sm font-medium text-white uppercase tracking-widest">Get Started</h4>
        <p class="mt-4 text-sm font-light text-slate-400 leading-relaxed">
          Book a free trial class for your child. No payment, no commitment.
        </p>
        <a href="/free-trial" class="inline-flex items-center justify-center mt-4 bg-pink-500 text-white text-sm font-medium py-3 px-6 rounded-lg hover:bg-pink-600 transition-colors duration-200">
          Book Free Trial
        </a>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-12 pt-6 border-t border-slate-800 flex flex-col md:flex-row items-center justify-between text-center gap-4">
      <p class="text-xs text-slate-500 font-light">
        &copy; 2026 Kids Soccer Academy. All rights reserved.
      </p>
      <div class="text-xs text-slate-500 font-light flex items-center gap-2">
        <a href="#" class="hover:text-slate-400 transition-colors">Privacy Policy</a>
        <span class="text-slate-700">|</span>
        <a href="#" class="hover:text-slate-400 transition-colors">Terms of Service</a>
      </div>
    </div>

  </div>
</footer>
